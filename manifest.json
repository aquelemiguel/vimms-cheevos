{
	"name": "Example Extension",
	"version": "1.0.0",
	"manifest_version": 3,
	"background": {
		"service_worker": "src/services/ra-client.ts"
	},
	"content_scripts": [
		{
			"matches": ["*://vimm.net/*"],
			"js": [
				"src/scripts/sidebar-settings.ts",
				"src/scripts/game-page-scraper.ts"
			]
		}
	],
	"web_accessible_resources": [
		{
			"resources": ["assets/ra-logo.png"],
			"matches": ["*://vimm.net/*"]
		}
	],
	"host_permissions": ["https://retroachievements.org/*"],
	"options_page": "src/options.html"
}
