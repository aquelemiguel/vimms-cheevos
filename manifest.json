{
	"name": "Example Extension",
	"version": "1.0.0",
	"manifest_version": 3,
	"background": {
		"service_worker": "src/services/ra-client.ts"
	},
	"permissions": ["storage"],
	"content_scripts": [
		{
			"matches": ["*://vimm.net/*"],
			"js": ["src/scripts/sidebar.ts", "src/scripts/game-page.ts"]
		}
	],
	"host_permissions": ["https://retroachievements.org/*"]
}
